# App
# Public deployment origin used in invite emails (no trailing slash).
# Use http://localhost:3000 only in local development.
NEXT_PUBLIC_APP_URL=https://podcazt.example.com
SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_VIDEOS_BUCKET=videos

# PostgreSQL for Prisma. For serverless deployments, use Supabase's transaction pooler.
# Copy its exact host from Supabase's Connect dialog; `pgbouncer=true` disables prepared statements.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Upstash Redis REST. Used for distributed API rate limiting.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Gmail invite delivery. Use a Google account email and a Google App Password.
# If these are omitted, invites are still created but emails are skipped.
GOOGLE_EMAIL=your-google-email@gmail.com
GOOGLE_APP_PASSWORD=your-16-character-google-app-password
GOOGLE_FROM_NAME=Podcazt
