# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_VIDEOS_BUCKET=videos

# PostgreSQL for Prisma. This can be your Supabase pooled Postgres connection string.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?schema=public

# Upstash Redis REST. Used for distributed API rate limiting.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Gmail invite delivery. Use a Google account email and a Google App Password.
# If these are omitted, invites are still created but emails are skipped.
GOOGLE_EMAIL=your-google-email@gmail.com
GOOGLE_APP_PASSWORD=your-16-character-google-app-password
GOOGLE_FROM_NAME=Podcazt
